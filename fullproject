/* ==================================================
   SYNTRA SENIOR DASHBOARD SYSTEM
================================================== */

:root {

    --bg-primary: #060816;
    --bg-secondary: #0f1428;
    --bg-card: rgba(16,21,40,0.78);

    --text-primary: #f5f7ff;
    --text-secondary: #95a2c6;

    --cyan: #00f0ff;
    --purple: #6c63ff;
    --green: #00d084;
    --orange: #ffb020;
    --red: #ff5c72;

    --border:
        rgba(255,255,255,0.08);

    --glass:
        rgba(255,255,255,0.04);
}

html {
    scroll-behavior: smooth;
}

body {

    min-height: 100vh;

    overflow-x: hidden;

    color: var(--text-primary);

    font-family:
        Inter,
        system-ui,
        sans-serif;

    background:
        radial-gradient(
            circle at top left,
            #1a2242,
            #060816 60%
        );

    position: relative;
}

/* ==========================================
   NOISE
========================================== */

body::before {

    content: "";

    position: fixed;

    inset: 0;

    pointer-events: none;

    opacity: 0.03;

    background-image:
        radial-gradient(
            rgba(255,255,255,.4) 1px,
            transparent 1px
        );

    background-size:
        24px 24px;

    z-index: -1;
}

/* ==========================================
   SCROLLBAR
========================================== */

::-webkit-scrollbar {
    width: 10px;
}

::-webkit-scrollbar-track {
    background: #090d1a;
}

::-webkit-scrollbar-thumb {

    background:
        linear-gradient(
            var(--cyan),
            var(--purple)
        );

    border-radius: 20px;
}

/* ==========================================
   LAYOUT
========================================== */

.app-layout {

    min-height: 100vh;

    display: flex;
}

.dashboard-container {

    flex: 1;

    padding: 28px;

    overflow-x: hidden;
}

/* ==========================================
   SIDEBAR
========================================== */

.sidebar {

    width: 290px;

    flex-shrink: 0;

    background:
        rgba(10,14,28,.86);

    backdrop-filter:
        blur(30px);

    border-right:
        1px solid var(--border);

    display: flex;

    flex-direction: column;

    position: sticky;

    top: 0;

    height: 100vh;
}

.sidebar-brand {

    display: flex;

    align-items: center;

    gap: 14px;
}

.sidebar-brand-logo {

    width: 80px;
    height: 80px;

    border-radius: 18px;

    overflow: hidden;

    background:
        rgba(255,255,255,.04);

    border:
        1px solid var(--border);
}

.sidebar-brand-logo img {

    width: 100%;
    height: 100%;

    object-fit: contain;

    padding: 6px;
}

.sidebar-nav-item {

    display: flex;

    align-items: center;

    gap: 14px;

    margin: 6px 12px;

    padding: 14px 16px;

    border-radius: 14px;

    color:
        var(--text-secondary);

    text-decoration: none;

    transition:
        .25s ease;
}

.sidebar-nav-item:hover {

    background:
        rgba(0,240,255,.08);

    color:
        white;

    transform:
        translateX(4px);
}

.sidebar-nav-item.active {

    background:
        rgba(0,240,255,.12);

    border:
        1px solid rgba(
            0,
            240,
            255,
            .15
        );

    color:
        var(--cyan);
}

.sidebar-nav-icon {

    width: 22px;
    height: 22px;

    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;

    filter:
        brightness(1.3);
}

/* ==========================================
   NAVBAR
========================================== */

.navbar {

    display: flex;

    align-items: center;

    justify-content: space-between;

    gap: 20px;

    margin-bottom: 30px;

    border-radius: 22px;

    padding: 18px 22px;

    background:
        rgba(16,21,40,.65);

    border:
        1px solid var(--border);

    backdrop-filter:
        blur(20px);
}

.navbar-search input {

    width: 360px;

    max-width: 100%;

    border-radius: 14px;

    border:
        1px solid var(--border);

    background:
        rgba(255,255,255,.03);

    color:
        white;

    padding:
        14px 18px;
}

.navbar-search input:focus {

    outline: none;

    border-color:
        rgba(0,240,255,.4);

    box-shadow:
        0 0 0 3px
        rgba(0,240,255,.08);
}

.navbar-icon-btn {

    width: 42px;
    height: 42px;

    border-radius: 12px;

    border:
        1px solid var(--border);

    background:
        rgba(255,255,255,.03);

    display: flex;
    align-items: center;
    justify-content: center;
}

.notification-badge {

    background:
        var(--cyan);

    color: black;

    font-weight: 700;
}

/* ==========================================
   GRID
========================================== */

.dashboard-grid {

    display: grid;

    grid-template-columns:
        repeat(
            auto-fit,
            minmax(
                320px,
                1fr
            )
        );

    gap: 24px;
}

/* ==========================================
   CARDS
========================================== */

.card {

    background:
        var(--bg-card);

    backdrop-filter:
        blur(20px);

    border:
        1px solid var(--border);

    border-radius: 24px;

    padding: 24px;

    box-shadow:
        0 10px 40px
        rgba(0,0,0,.35);

    transition:
        .25s ease;
}

.card:hover {

    transform:
        translateY(-5px);

    border-color:
        rgba(0,240,255,.16);

    box-shadow:
        0 20px 50px
        rgba(0,0,0,.45);
}

/* ==========================================
   METRICS
========================================== */

.metric-widget {

    min-height: 180px;

    display: flex;

    flex-direction: column;

    justify-content: space-between;
}

.metric-top {

    display: flex;

    justify-content: space-between;

    align-items: center;
}

.metric-icon {

    width: 52px;
    height: 52px;

    border-radius: 16px;

    background:
        rgba(255,255,255,.04);

    border:
        1px solid var(--border);

    display: flex;

    align-items: center;

    justify-content: center;
}

.metric-icon img {

    width: 24px;
    height: 24px;

    object-fit: contain;
}

.metric-growth {

    font-size: 13px;

    font-weight: 700;

    color:
        var(--green);
}

.metric-title {

    color:
        var(--text-secondary);

    font-size: 13px;

    letter-spacing: .5px;
}

.metric-value {

    font-size: 34px;

    font-weight: 800;

    color:
        white;
}

/* ==========================================
   WIDGETS
========================================== */

.widget-header {

    display: flex;

    justify-content: space-between;

    align-items: center;

    margin-bottom: 20px;
}

.widget-header h3 {

    font-size: 15px;

    font-weight: 700;
}

.widget-action {

    border: none;

    cursor: pointer;

    border-radius: 12px;

    padding: 8px 14px;

    background:
        rgba(0,240,255,.12);

    color:
        var(--cyan);
}

.widget-body {

    height: 320px;
}

.widget canvas {

    width: 100% !important;
    height: 100% !important;
}

/* ==========================================
   TOP PAGES
========================================== */

.top-pages-list {

    display: flex;

    flex-direction: column;

    gap: 14px;
}

.top-page-row {

    display: flex;

    justify-content: space-between;

    align-items: center;

    padding-bottom: 10px;

    border-bottom:
        1px solid rgba(
            255,
            255,
            255,
            .05
        );
}

.top-page-name {

    color:
        white;
}

.top-page-views {

    color:
        var(--cyan);

    font-weight: 700;
}

/* ==========================================
   HEATMAP
========================================== */

.syntra-heatmap {

    display: grid;

    grid-template-columns:
        repeat(7,1fr);

    gap: 10px;
}

.heatmap-cell {

    height: 42px;

    border-radius: 10px;

    background:
        var(--cyan);

    color: black;

    font-size: 12px;

    font-weight: 700;

    display: flex;

    align-items: center;

    justify-content: center;
}

/* ==========================================
   MODAL
========================================== */

.syntra-modal-window {

    width: 520px;

    max-width: 92vw;

    background:
        rgba(16,21,40,.96);

    border:
        1px solid var(--border);

    border-radius: 22px;

    overflow: hidden;
}

.syntra-modal-btn {

    border: none;

    cursor: pointer;

    background:
        var(--cyan);

    color: black;

    font-weight: 700;

    padding: 12px 20px;

    border-radius: 12px;
}

/* ==========================================
   TOAST
========================================== */

#syntra-toast-container {

    position: fixed;

    right: 20px;
    bottom: 20px;

    display: flex;

    flex-direction: column;

    gap: 12px;

    z-index: 99999;
}

.syntra-toast {

    min-width: 280px;

    padding: 14px 18px;

    border-radius: 14px;

    background:
        rgba(16,21,40,.96);

    border:
        1px solid var(--border);

    color: white;
}

.syntra-toast-success {
    border-left: 4px solid var(--green);
}

.syntra-toast-error {
    border-left: 4px solid var(--red);
}

.syntra-toast-warning {
    border-left: 4px solid var(--orange);
}

/* ==========================================
   RESPONSIVE
========================================== */

@media (max-width: 1100px) {

    .sidebar {

        width: 90px;
    }

    .sidebar-nav-label,
    .sidebar-brand-content {

        display: none;
    }
}

@media (max-width: 768px) {

    .sidebar {
        display: none;
    }

    .dashboard-container {
        padding: 18px;
    }

    .navbar {

        flex-direction: column;

        align-items: stretch;
    }

    .navbar-search input {

        width: 100%;
    }

    .metric-value {

        font-size: 28px;
    }

    .widget-body {

        height: 260px;
    }
}
